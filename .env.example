# Google Gemini API — enables the AI announcement summary.
# Get a key at https://aistudio.google.com/apikey then copy this file to `.env`.
VITE_GEMINI_API_KEY=your_api_key_here

# Optional fallback key — used automatically if the primary key fails
# (e.g. rate limit / quota exceeded).
VITE_GEMINI_API_KEY_2=your_second_api_key_here

# Optional: override the model (defaults to gemini-2.0-flash).
# VITE_GEMINI_MODEL=gemini-2.0-flash
